<?xml version="1.0"?>
<robot name="peon_movil">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://peon_movil_description/urdf/meshes_stl/base.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="base_link_mat"><color rgba="0.3 0.3 0.35 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry><box size="0.241 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.00000 0.00000 0.00000" rpy="0 0 0"/>
      <mass value="1.4000"/>
      <inertia ixx="5.833333e-03" ixy="0" ixz="0" iyy="7.942783e-03" iyz="0" izz="1.144278e-02"/>
    </inertial>
  </link>

  <link name="wheel_fl">
