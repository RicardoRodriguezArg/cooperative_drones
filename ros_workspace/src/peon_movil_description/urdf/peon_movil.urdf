    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.041" length="0.0425"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.00000 0.00000 0.00000" rpy="0 0 0"/>
      <mass value="0.0850"/>
      <inertia ixx="4.851552e-05" ixy="0" ixz="0" iyy="7.144250e-05" iyz="0" izz="4.851552e-05"/>
    </inertial>
  </link>
  <joint name="wheel_fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fl"/>
    <origin xyz="0.0855 0.0873 -0.0412" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

